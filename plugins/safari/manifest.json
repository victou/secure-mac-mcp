{
  "id": "safari",
  "tools": [
    {
      "name": "safari.open_url",
      "description": "Open an HTTP or HTTPS URL in Safari.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["url"],
        "properties": {
          "url": {
            "type": "string",
            "pattern": "^https?://",
            "description": "The HTTP or HTTPS URL to open."
          }
        }
      },
      "requiresApproval": true
    }
  ]
}
