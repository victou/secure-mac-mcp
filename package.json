{
  "name": "secure-mac-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx packages/mcp-server/src/index.ts",
    "approval:list": "tsx packages/mcp-server/src/approval-cli.ts list",
    "approval:approve": "tsx packages/mcp-server/src/approval-cli.ts approve",
    "approval:deny": "tsx packages/mcp-server/src/approval-cli.ts deny",
    "desktop:dev": "pnpm --filter @secure-mac-mcp/desktop tauri:dev",
    "desktop:build": "pnpm --filter @secure-mac-mcp/desktop tauri:build",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.1",
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.10.7",
    "eslint": "^9.39.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.46.3",
    "vitest": "^2.1.9"
  }
}
